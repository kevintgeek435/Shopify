<style>
.review-rating__block {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: .6rem;
  margin-bottom: 1.2rem;
}
.review-rating__block .star-rating {
  color: var(--star-color);
}
.review-rating__block .star-rating__star {
  width: 100%;
  height: 100%;
  display: block;
  color: rgba(0, 0, 0, 0.12);
}
</style>

<div class="review-rating__block">
  {% render 'rating',
    rating: block.settings.rating,
    star_color: block.settings.star_color,
    section_id: section.id | append: '-' | append: block.id
  %}
  <span class="review-count">{{ block.settings.review_text }}</span>
</div>


# rating snnipet code below 👎 👎 👎 👎 
<div class="star-rating inline-flex" style="--star-color: {{ star_color }}">
  {% assign rating = rating | plus: 0 %}
  {% assign rating_int = rating | floor %}
  {% assign rating_fraction = rating | minus: rating_int %}
  {% assign next_star = rating_int | plus: 1 %}

  {% for i in (1..5) %}
    {% assign star_fill = 0 %}
    {% if i <= rating_int %}
      {% assign star_fill = 100 %}
    {% elsif i == next_star %}
      {% assign star_fill = rating_fraction | times: 100 | round %}
    {% endif %}

    {% assign gradient_id = 'star-grad-'
      | append: section_id
      | append: '-'
      | append: forloop.index
    %}

    <svg
      width="16"
      height="16"
      viewBox="0 0 16 16"
      class="star-rating__star"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
      focusable="false"
    >
      <defs>
        <linearGradient id="{{ gradient_id }}" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="{{ star_color }}" />
          <stop offset="{{ star_fill }}%" stop-color="{{ star_color }}" />
          <stop offset="{{ star_fill }}%" stop-color="rgba(0, 0, 0, 0.12)" />
          <stop offset="100%" stop-color="rgba(0, 0, 0, 0.12)" />
        </linearGradient>
      </defs>
      <path
        d="M14.9483 6.07866C14.8858 5.88649 14.7678 5.71712 14.6092 5.59188C14.4506 5.46665 14.2585 5.39116 14.0571 5.37491L10.3696 5.07741L8.9458 1.63429C8.86881 1.44667 8.73776 1.28619 8.56932 1.17325C8.40088 1.06031 8.20267 1 7.99987 1C7.79707 1 7.59885 1.06031 7.43041 1.17325C7.26197 1.28619 7.13093 1.44667 7.05393 1.63429L5.63143 5.07679L1.94205 5.37491C1.74029 5.39198 1.54805 5.4682 1.38941 5.59404C1.23078 5.71988 1.11281 5.88973 1.05028 6.08232C0.987751 6.27491 0.983448 6.48167 1.03791 6.67669C1.09237 6.87172 1.20317 7.04633 1.35643 7.17866L4.16893 9.60554L3.31205 13.2343C3.26413 13.4314 3.27587 13.6384 3.34577 13.8288C3.41567 14.0193 3.54058 14.1847 3.70465 14.304C3.86873 14.4234 4.06456 14.4913 4.26729 14.4991C4.47002 14.5069 4.67051 14.4544 4.8433 14.348L7.99955 12.4055L11.1577 14.348C11.3305 14.4531 11.5306 14.5047 11.7327 14.4962C11.9348 14.4878 12.1299 14.4198 12.2934 14.3007C12.4569 14.1816 12.5816 14.0168 12.6516 13.8271C12.7217 13.6373 12.734 13.431 12.6871 13.2343L11.8271 9.60491L14.6396 7.17804C14.7941 7.04593 14.9059 6.87093 14.9608 6.67522C15.0158 6.47951 15.0114 6.27189 14.9483 6.07866Z"
        fill="url(#{{ gradient_id }})"
      />
    </svg>
  {% endfor %}
</div>

